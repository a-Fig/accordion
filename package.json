{
	"name": "accordion",
	"keywords": [
		"pi-package"
	],
	"main": "src/accordion.ts",
	"type": "module",
	"pi": {
		"extensions": [
			"./src/accordion.ts"
		]
	},
	"scripts": {
		"test": "node --test --test-concurrency=1 --experimental-strip-types src/*.test.ts",
		"test:claims": "node --test --experimental-strip-types src/claims.test.ts",
		"test:ollama": "node --test --experimental-strip-types src/ollama-summary.live.ts",
		"benchmark": "node --experimental-strip-types src/benchmark-niah.ts",
		"compare:compact": "node --experimental-strip-types src/compare-compact.ts",
		"model:audit-labels": "node --experimental-strip-types src/audit-conductor-labels.ts --data=data/conductor-training-v0.jsonl --min-agreement=1 --max-disagreements=0",
		"model:audit-teacher-labels": "node --experimental-strip-types src/audit-conductor-labels.ts --data=data/conductor-training-teacher.jsonl --out=docs/conductor-teacher-label-audit.json --min-agreement=1 --max-disagreements=0 --allow-extra-teacher-records",
		"model:export-data": "node --experimental-strip-types src/export-conductor-training-data.ts",
		"model:export-teacher-jobs": "node --experimental-strip-types src/export-conductor-teacher-label-jobs.ts --out=data/conductor-teacher-label-jobs.jsonl",
		"model:request-teacher-labels": "node --experimental-strip-types src/request-conductor-teacher-labels.ts --jobs=data/conductor-teacher-label-jobs.jsonl --out=data/conductor-teacher-labels.jsonl",
		"model:import-teacher-labels": "node --experimental-strip-types src/import-conductor-teacher-labels.ts --base=data/conductor-training-v0.jsonl --teacher-labels=data/conductor-teacher-labels.jsonl --out=data/conductor-training-teacher.jsonl --min-teacher-records=1",
		"model:evaluate": "node --experimental-strip-types src/evaluate-conductor-model.ts --model-artifact models/conductor-local-v1.json --model-authority models/conductor-local-v1.authority.json --min-conversations=16 --min-learned-score=1 --min-quality-delta=0 --min-token-delta=0 --min-quality-nonnegative-probability=0.95 --max-heuristic-wins=0 --max-token-regression-conversations=0 --max-budget-violations=0",
		"model:evaluate-compression": "node --experimental-strip-types src/evaluate-conductor-compression.ts --artifact=models/conductor-teacher-student-v1.json --out=docs/conductor-compression-evaluation.json --min-recall-delta=0 --max-fidelity-escapes=0 --min-teacher-digest-hits=1 --min-blocks=1",
		"model:promote-authority": "node --experimental-strip-types src/promote-conductor-model.ts --artifact=models/conductor-local-v1.json --label-audit=docs/conductor-label-audit.json --model-evaluation=docs/conductor-model-evaluation.json --out=models/conductor-local-v1.authority.json",
		"model:train-minilm-policy": "node --experimental-strip-types src/train-conductor-minilm-policy.ts --data=data/conductor-training-teacher.jsonl --out=models/conductor-minilm-policy-v1.json --min-teacher-records=1",
		"model:train-textual-compressor": "node --experimental-strip-types src/train-conductor-textual-compressor.ts --data=data/conductor-training-teacher.jsonl --out=models/conductor-textual-compressor-v1.json --min-teacher-compression-records=1",
		"model:train-teacher": "node --experimental-strip-types src/train-conductor-model.ts --data=data/conductor-training-teacher.jsonl --out=models/conductor-local-teacher-v1.json",
		"model:compose-teacher-student": "node --experimental-strip-types src/compose-conductor-teacher-student.ts --base=models/conductor-local-teacher-v1.json --fold-policy=models/conductor-minilm-policy-v1.json --compression=models/conductor-textual-compressor-v1.json --out=models/conductor-teacher-student-v1.json",
		"model:train": "node --experimental-strip-types src/train-conductor-model.ts",
		"proof:compact": "node --experimental-strip-types src/compare-compact.ts --embeddings --budgets=1500,2500,4000 --out=docs/compact-comparison-proof.json --markdown=docs/compact-comparison-proof.md --min-cells=30 --min-advantage=20 --min-accordion-score=100 --max-compact-wins=0 --max-accordion-budget-violations=0",
		"proof:semantic": "node --experimental-strip-types src/compare-compact.ts --embeddings --scenario=semantic-preference-late --budgets=1500 --out=docs/compact-comparison-semantic-proof.json --markdown=docs/compact-comparison-semantic-proof.md --answers --min-cells=1 --min-advantage=100 --min-accordion-score=100 --max-compact-wins=0 --max-accordion-budget-violations=0",
		"proof:semantic:cloud": "node --experimental-strip-types src/compare-compact.ts --embeddings --scenario=semantic-preference-late --budgets=1500 --out=docs/compact-comparison-semantic-cloud-proof.json --markdown=docs/compact-comparison-semantic-cloud-proof.md --answers --model=minimax-m3:cloud --min-cells=1 --min-advantage=100 --min-accordion-score=100 --max-compact-wins=0 --max-accordion-budget-violations=0",
		"proof:semantic:two-model": "npm run proof:semantic && npm run proof:semantic:cloud",
		"proof:judge": "node --experimental-strip-types src/compare-compact.ts --embeddings --category=semantic --budgets=1500,2500 --out=docs/compact-comparison-judge-semantic.json --markdown=docs/compact-comparison-judge-semantic.md --answers --min-cells=6 --min-advantage=50 --min-accordion-score=100 --max-compact-wins=0 --max-accordion-budget-violations=0",
		"proof:judge:llm": "node --experimental-strip-types src/compare-compact.ts --compact=llm --embeddings --category=semantic --budgets=1500,2500 --out=docs/compact-comparison-judge-llm-semantic.json --markdown=docs/compact-comparison-judge-llm-semantic.md --answers --min-cells=6 --min-advantage=50 --min-accordion-score=100 --max-compact-wins=0 --max-accordion-budget-violations=0",
		"proof:judge:all": "npm run proof:judge && npm run proof:judge:llm",
		"proof:report": "node --experimental-strip-types src/judge-report.ts",
		"proof:refresh": "npm run proof:compact && npm run proof:judge && npm run proof:judge:llm && npm run proof:semantic:two-model && npm run proof:report",
		"compact:external-template": "node --experimental-strip-types src/compare-compact.ts --category=semantic --budgets=1500,2500 --write-external-template=docs/compact-captures.template.json --write-external-guide=docs/compact-captures.guide.md",
		"proof:judge:external": "node --experimental-strip-types src/compare-compact.ts --compact=external --external-compact=docs/compact-captures.json --embeddings --category=semantic --budgets=1500,2500 --out=docs/compact-comparison-judge-external-semantic.json --markdown=docs/compact-comparison-judge-external-semantic.md --answers --min-cells=6 --min-advantage=50 --min-accordion-score=100 --max-compact-wins=0 --max-accordion-budget-violations=0",
		"benchmark:quick": "node --experimental-strip-types src/benchmark-niah.ts --lengths 2000,5000 --depths 0.1,0.5,0.9 --budgets 1.0,0.7,0.5",
		"benchmark:model:quick": "node --experimental-strip-types src/benchmark-niah.ts --offline-answer --local-model --model-artifact models/conductor-local-v1.json --model-authority models/conductor-local-v1.authority.json --working-tail-tokens 0 --lengths 2000,5000 --depths 0.1,0.5,0.9 --budgets 1.0,0.7,0.5",
		"benchmark:stress": "node --experimental-strip-types src/benchmark-niah.ts --lengths 10000,20000 --budgets 1.0,0.7,0.5 --runs 2",
		"benchmark:indirect": "node --experimental-strip-types src/benchmark-niah.ts --lengths 10000,20000 --probe indirect --budgets 1.0,0.7,0.5 --runs 2 --out benchmark-indirect.json",
		"benchmark:multi": "node --experimental-strip-types src/benchmark-niah.ts --mode multi-key --lengths 10000,20000",
		"benchmark:verbose": "node --experimental-strip-types src/benchmark-niah.ts --lengths 5000,10000 --depths 0.1,0.5,0.9 --budgets 1.0,0.7 --verbose --out benchmark-verbose.json",
		"benchmark:gemini": "node --experimental-strip-types src/benchmark-niah.ts --base-url https://generativelanguage.googleapis.com/v1beta/openai --model gemini-2.5-flash --api-key $GOOGLE_API_KEY --lengths 5000,10000,20000 --depths 0.1,0.25,0.5,0.75,0.9 --budgets 1.0,0.9,0.7,0.5 --runs 3 --out benchmark-gemini.json",
		"benchmark:gemini-indirect": "node --experimental-strip-types src/benchmark-niah.ts --base-url https://generativelanguage.googleapis.com/v1beta/openai --model gemini-2.5-flash --api-key $GOOGLE_API_KEY --probe indirect --lengths 5000,10000,20000 --depths 0.1,0.25,0.5,0.75,0.9 --budgets 1.0,0.9,0.7,0.5 --runs 3 --out benchmark-gemini-indirect.json",
		"benchmark:groq": "node --experimental-strip-types src/benchmark-niah.ts --base-url https://api.groq.com/openai/v1 --model llama-3.3-70b-versatile --api-key $GROQ_API_KEY --lengths 5000,10000,20000 --depths 0.1,0.25,0.5,0.75,0.9 --budgets 1.0,0.9,0.7,0.5 --runs 3 --out benchmark-groq.json",
		"benchmark:groq-indirect": "node --experimental-strip-types src/benchmark-niah.ts --base-url https://api.groq.com/openai/v1 --model llama-3.3-70b-versatile --api-key $GROQ_API_KEY --probe indirect --lengths 5000,10000,20000 --depths 0.1,0.25,0.5,0.75,0.9 --budgets 1.0,0.9,0.7,0.5 --runs 3 --out benchmark-groq-indirect.json",
		"test:e2e": "node --test --experimental-strip-types test/e2e-demo.test.ts",
		"evidence": "node --experimental-strip-types src/generate-evidence.ts",
		"demo": "node --experimental-strip-types src/generate-demo-transcript.ts"
	},
	"dependencies": {
		"ws": "^8.21.0"
	},
	"optionalDependencies": {
		"@huggingface/transformers": "^3.8.1"
	}
}
