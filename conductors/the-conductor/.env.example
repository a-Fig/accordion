# The Conductor — environment configuration. Copy to .env.local (git-ignored) and edit.
# Every knob is optional; with none set the conductor runs deterministic-only (keyword
# relevance + deterministic digests) and still defends the budget correctly.

# ── WebSocket ──────────────────────────────────────────────────────────────────
# CONDUCTOR_PORT=7703              # recency=7700, attention=7701, tiered=7702, this=7703

# ── Relevance: embeddings (bi-encoder) ──────────────────────────────────────────
# Attempted by default; requires the optional @huggingface/transformers dependency.
# ACCORDION_EMBEDDINGS=0           # set to 0/false to force keyword-only relevance
# ACCORDION_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ── Relevance: cross-encoder rerank (two-stage, opt-in) ─────────────────────────
# ACCORDION_RERANK=1               # enable the cross-encoder rescue of the folded shortlist
# ACCORDION_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# ── LLM digests (async, off the critical path; deterministic digest until they land) ──
# Auto-selection: a configured cloud key (Anthropic → Gemini) wins; else deterministic.
# Ollama is opt-in so an unconfigured run never calls a local endpoint that may be down.
# ACCORDION_SUMMARY_PROVIDER=anthropic   # anthropic | gemini | ollama | none
# ACCORDION_SUMMARIES=0                   # hard-disable LLM summaries
# ANTHROPIC_API_KEY=
# ANTHROPIC_SUMMARY_MODEL=claude-haiku-4-5
# GOOGLE_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_SUMMARY_MODEL=llama3.2:3b

# ── Strategy tuning (passed through to the vendored core; see strategy.ts constants) ──
# ACCORDION_FIXED_TARGET=0.8       # pin the fold target, disabling self-calibration
# ACCORDION_UNFOLD_MARGIN=0.08     # proactive-unfold relative-outlier margin
# ACCORDION_UNFOLD_FLOOR=0.30      # proactive-unfold absolute cosine floor
# ACCORDION_HYSTERESIS=0.05        # level-change deadband
